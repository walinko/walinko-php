parameters:
  level: 6
  paths:
    - src
    - tests
  treatPhpDocTypesAsCertain: false
  reportUnmatchedIgnoredErrors: false
  ignoreErrors:
    # `tests/Support/MockHttpClient::pushResponse` accepts loose mixed
    # body shapes for ergonomics.
    - identifier: missingType.iterableValue
      paths:
        - tests/Support/MockHttpClient.php
    # `new Client([])` test deliberately omits required api_key.
    -
      message: '#Walinko\\Client::__construct\(\) expects array#'
      path: tests/ClientTest.php
