{
  "name": "walinko/sdk",
  "description": "Official PHP SDK for the Walinko public API.",
  "type": "library",
  "license": "MIT",
  "homepage": "https://github.com/walinko/walinko-sdk",
  "support": {
    "issues": "https://github.com/walinko/walinko-sdk/issues",
    "source": "https://github.com/walinko/walinko-sdk/tree/main/sdks/php",
    "docs": "https://walinko.com/docs/api"
  },
  "keywords": ["walinko", "whatsapp", "sdk", "messaging", "api"],
  "authors": [
    { "name": "Walinko", "email": "support@walinko.com" }
  ],
  "require": {
    "php": ">=8.1",
    "psr/http-client": "^1.0",
    "psr/http-factory": "^1.0",
    "psr/http-message": "^1.0 || ^2.0",
    "psr/log": "^2.0 || ^3.0",
    "php-http/discovery": "^1.19"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "symfony/http-client": "^6.4 || ^7.0",
    "nyholm/psr7": "^1.8",
    "friendsofphp/php-cs-fixer": "^3.59",
    "phpstan/phpstan": "^1.11"
  },
  "autoload": {
    "psr-4": { "Walinko\\": "src/" }
  },
  "autoload-dev": {
    "psr-4": { "Walinko\\Tests\\": "tests/" }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "php-http/discovery": true
    }
  },
  "extra": {
    "branch-alias": {
      "dev-main": "0.1.x-dev"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
